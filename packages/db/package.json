{
  "name": "@aani/db",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "check-types": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:apply": "node --env-file=../../.env scripts/apply-migrations.mjs",
    "db:apply:dry": "node --env-file=../../.env scripts/apply-migrations.mjs --dry-run",
    "db:bootstrap": "node --env-file=../../.env scripts/apply-migrations.mjs --bootstrap",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.39.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.0",
    "typescript": "~5.9.2"
  }
}
