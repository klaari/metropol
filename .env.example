# Clerk Authentication
# Get from https://dashboard.clerk.com → API Keys
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Neon Database (serverless Postgres)
# Get from https://console.neon.tech → Connection Details → Connection string
EXPO_PUBLIC_DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Cloudflare R2
# Endpoint: Settings → R2 → Overview → S3 API URL (https://<account-id>.r2.cloudflarestorage.com)
# Access key: Manage R2 API Tokens → Create API Token
EXPO_PUBLIC_R2_ENDPOINT=https://25d8bcc50acc7af761cc147a91411053.r2.cloudflarestorage.com
EXPO_PUBLIC_R2_ACCESS_KEY=...
EXPO_PUBLIC_R2_SECRET_KEY=...
EXPO_PUBLIC_R2_BUCKET=aani-player
